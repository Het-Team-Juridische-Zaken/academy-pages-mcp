# De Academy-site waar pagina's op komen
SP_SITE_URL=https://stamadvocaten.sharepoint.com/sites/Academy

# Entra-app en tenant.
# Dit is de eigen HTJZ-app "Academy Pages" (delegated, Optie A), aangemaakt 18 juli 2026.
# Voor een demo zonder eigen app kun je ook de publieke Graph CLI-app 14d82eec-204b-4c2f-b7e8-296a70dab67e gebruiken.
GRAPH_CLIENT_ID=646a6353-f18d-4566-84a9-73b2a8d9f23d
GRAPH_TENANT=stamadvocaten.onmicrosoft.com

# Benodigde scope. Delegated (namens de ingelogde gebruiker):
GRAPH_SCOPES=Sites.ReadWrite.All
